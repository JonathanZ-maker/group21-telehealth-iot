# Copy this file to .env and fill in real values.
# .env is gitignored — NEVER commit the filled version.

# ---- YYX: MongoDB Atlas connection ----
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/telehealth?retryWrites=true&w=majority

# ---- LYZ: HMAC shared secret for wearable <-> gateway (dev placeholder) ----
HMAC_DEVICE_SECRET=change-me-to-a-32-byte-random-hex

# ---- ZYM: JWT signing key for cloud_auth.py ----
ZYM_JWT_SECRET=change-me-to-a-48-byte-random-urlsafe-string

# ---- ZYM: Differential-privacy engine ----
ZYM_DP_EPSILON=1.0
ZYM_DP_CLIP_WINDOW=30.0

# ---- Service endpoints ----
GATEWAY_URL=http://127.0.0.1:8000/upload
CLOUD_URL=http://127.0.0.1:5000
