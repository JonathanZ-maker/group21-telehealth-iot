# ---- Secrets ----
.env
*.pem
*.key
secrets/

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
*.egg-info/
.eggs/

# ---- Testing / coverage ----
.pytest_cache/
.coverage
htmlcov/
.tox/

# ---- IDE ----
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ---- Jupyter ----
.ipynb_checkpoints/

# ---- Data ----
# Raw datasets are too large for git; fetch them via scripts/fetch_data.sh
data/raw/*
!data/raw/.gitkeep
!data/raw/README.md

# Keep processed smaller derivatives
# data/processed/  — tracked by default, comment the next line to exclude large files
# data/processed/*.csv

# ---- Models (keep small ones, ignore large) ----
# zym_defense/models/iforest.pkl is expected to be < 5 MB — keep it tracked
# but any larger .pkl/.joblib should go to Git LFS
*.joblib
# Uncomment if your pickle gets too big:
# zym_defense/models/*.pkl

# ---- Report build artifacts ----
report/*.aux
report/*.log
report/*.out
report/*.toc
report/*.synctex.gz
report/_build/

# ---- Output / temporary ----
*.tmp
*.bak
*.log
# but keep sample log captures used for report screenshots
!report/figures/*.log.png
